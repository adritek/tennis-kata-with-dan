{
  "compilerOptions": {
    /* Base Options */
    "target": "ES2022",
    "module": "Node20",
    "moduleResolution": "Node16",
    "outDir": "./dist",
    "isolatedModules": true,
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": true,
    "alwaysStrict": true,

    /* Additional Checks */
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
